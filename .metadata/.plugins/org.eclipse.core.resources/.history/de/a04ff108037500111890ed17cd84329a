#ifndef COMM_H
#define COMM_H

#include "stm32f4xx_hal.h"
#include <stdint.h>

// ─── Frame Format ─────────────────────────────────────────────────────────────
// [0xAA][0x55][0xA5][TYPE:1][LEN:1][PAYLOAD:N][CRC8:1]
// 3-byte sync dramatically reduces false syncs inside binary payload data.
// False sync probability: ~1/16M per byte vs ~1/65K with 2-byte sync.
#define COMM_SYNC1              0xAA
#define COMM_SYNC2              0x55
#define COMM_SYNC3              0xA5   // ← new third sync byte
#define COMM_RX_BUF_SIZE        64
#define COMM_TX_BUF_SIZE        64     // Motor FB frame = 44 bytes total
// Maximum payload that fits: buffer minus 3 sync + type + len + crc (6 bytes overhead)
#define COMM_MAX_PAYLOAD    (COMM_TX_BUF_SIZE - 6u)   // = 58 bytes
//#define COMM_IMU_TX_BUF_SIZE    40     // IMU frame     = 38 bytes total

// ─── Message Types ────────────────────────────────────────────────────────────
typedef enum {
    MSG_CONTROL_CMD = 0x01,   // Host → STM32: velocity targets
    MSG_ACTUATOR_FB = 0x02,   // STM32 → Host: motor feedback
    MSG_HEARTBEAT   = 0x03,   // Bidirectional: keep-alive
    MSG_ESTOP       = 0x04,   // Host → STM32: emergency stop
//    MSG_IMU_DATA    = 0x05,   // STM32 → Host: IMU sensor data
} MsgType_t;

// ─── Payload Structs ──────────────────────────────────────────────────────────

typedef struct __attribute__((packed)) {
    int16_t vel_rpm10[4];   // Target RPM × 10
    uint8_t mode;           // 0=velocity PID, 1=open-loop PWM
} ControlCmd_t;             // 9 bytes

typedef struct __attribute__((packed)) {
    int16_t  vel_rpm10[4];  // Measured RPM × 10
    int32_t  enc_count[4];  // Absolute encoder counts
    int16_t  pwm_out[4];    // Applied PWM
    uint32_t timestamp_ms;  // HAL_GetTick()
    uint8_t  sys_status;    // Bit0: IMU OK, Bit1: WARN, Bit2: FAULT
} ActuatorFB_t;             // 37 bytes

