/* ========== motor_control.c ========== */
#include "motor_control.h"
#include "tim.h"
#include "main.h"
#include <stdlib.h>

#define PWM_DEADBAND  150
#define PWM_RAMP_STEP 300

static MotorState_t state[MOTOR_COUNT];
static int16_t      s_current_pwm[MOTOR_COUNT] = {0, 0, 0, 0};

void Motor_Init(void)
{
    /* Motor 0, 1, 2: TIM1 CH1/2/3 + complementary */
    HAL_TIM_PWM_Start(&htim1, TIM_CHANNEL_1);
    HAL_TIMEx_PWMN_Start(&htim1, TIM_CHANNEL_1);
    HAL_TIM_PWM_Start(&htim1, TIM_CHANNEL_2);
    HAL_TIMEx_PWMN_Start(&htim1, TIM_CHANNEL_2);
    HAL_TIM_PWM_Start(&htim1, TIM_CHANNEL_3);
    HAL_TIMEx_PWMN_Start(&htim1, TIM_CHANNEL_3);
    __HAL_TIM_MOE_ENABLE(&htim1);

    /* Motor 3: TIM10 (RPWM) and TIM11 (LPWM) */
    HAL_TIM_PWM_Start(&htim10, TIM_CHANNEL_1);
    HAL_TIM_PWM_Start(&htim11, TIM_CHANNEL_1);

    /* FIX: disable TIM10/TIM11 output compares immediately after start so
       Motor 3 powers up in coast state, identical to motors 0-2 whose
       CCER bits are cleared by Motor_CoastAll() below. */
    TIM10->CCER &= ~TIM_CCER_CC1E;
    TIM11->CCER &= ~TIM_CCER_CC1E;

    Motor_CoastAll();
}

void Motor_Set(uint8_t id, int16_t target_pwm_signed)
{
    if (id >= MOTOR_COUNT) return;

    if (abs(target_pwm_signed) < PWM_DEADBAND) {
        target_pwm_signed = 0;
    }

    if (target_pwm_signed >  (int16_t)PWM_MAX) target_pwm_signed =  (int16_t)PWM_MAX;
    if (target_pwm_signed < -(int16_t)PWM_MAX) target_pwm_signed = -(int16_t)PWM_MAX;

    /* Slew-rate limiter */
    int16_t current = s_current_pwm[id];
    if (target_pwm_signed > current) {
        current += PWM_RAMP_STEP;
        if (current > target_pwm_signed) current = target_pwm_signed;
    } else if (target_pwm_signed < current) {
        current -= PWM_RAMP_STEP;
        if (current < target_pwm_signed) current = target_pwm_signed;
    }
    s_current_pwm[id] = current;

    uint16_t   duty = (uint16_t)abs(current);
    MotorDir_t dir  = (current > 0) ? MOTOR_DIR_FORWARD :
                      (current < 0) ? MOTOR_DIR_REVERSE : MOTOR_DIR_COAST;

    switch (id)
    {
        case 0: /* TIM1 CH1 (PA8) / CH1N (PB13) */
            TIM1->CCR1 = duty;
            if (dir == MOTOR_DIR_FORWARD) {
                TIM1->CCER |=  TIM_CCER_CC1E;
                TIM1->CCER &= ~TIM_CCER_CC1NE;
            } else if (dir == MOTOR_DIR_REVERSE) {
                TIM1->CCER &= ~TIM_CCER_CC1E;
                TIM1->CCER |=  TIM_CCER_CC1NE;
            } else {
                TIM1->CCER &= ~(TIM_CCER_CC1E | TIM_CCER_CC1NE);
                TIM1->CCR1  = 0;
            }
            break;

        case 1: /* TIM1 CH2 (PA9) / CH2N (PB14) */
            TIM1->CCR2 = duty;
            if (dir == MOTOR_DIR_FORWARD) {
                TIM1->CCER |=  TIM_CCER_CC2E;
                TIM1->CCER &= ~TIM_CCER_CC2NE;
            } else if (dir == MOTOR_DIR_REVERSE) {
                TIM1->CCER &= ~TIM_CCER_CC2E;
                TIM1->CCER |=  TIM_CCER_CC2NE;
            } else {
                TIM1->CCER &= ~(TIM_CCER_CC2E | TIM_CCER_CC2NE);
                TIM1->CCR2  = 0;
            }
            break;

        case 2: /* TIM1 CH3 (PA10) / CH3N (PB15) */
            TIM1->CCR3 = duty;
            if (dir == MOTOR_DIR_FORWARD) {
                TIM1->CCER |=  TIM_CCER_CC3E;
                TIM1->CCER &= ~TIM_CCER_CC3NE;
            } else if (dir == MOTOR_DIR_REVERSE) {
                TIM1->CCER &= ~TIM_CCER_CC3E;
                TIM1->CCER |=  TIM_CCER_CC3NE;
            } else {
                TIM1->CCER &= ~(TIM_CCER_CC3E | TIM_CCER_CC3NE);
                TIM1->CCR3  = 0;
            }
            break;

        case 3: /* TIM10 CH1 (PB8) = RPWM,  TIM11 CH1 (PB9) = LPWM */
            /* FIX: gate the output via CCER, not just CCR.
               Setting CCR=0 on an always-enabled channel still produces a
               narrow pulse on some timer configurations.  Mirror the same
               enable/disable pattern used for motors 0-2 on TIM1. */
            if (dir == MOTOR_DIR_FORWARD) {
                TIM11->CCR1  = 0;
                TIM11->CCER &= ~TIM_CCER_CC1E;  /* disable LPWM first */
                TIM10->CCR1  = duty;
                TIM10->CCER |=  TIM_CCER_CC1E;  /* enable  RPWM */
            } else if (dir == MOTOR_DIR_REVERSE) {
                TIM10->CCR1  = 0;
                TIM10->CCER &= ~TIM_CCER_CC1E;  /* disable RPWM first */
                TIM11->CCR1  = duty;
                TIM11->CCER |=  TIM_CCER_CC1E;  /* enable  LPWM */
            } else {
                TIM10->CCR1  = 0;
                TIM11->CCR1  = 0;
                TIM10->CCER &= ~TIM_CCER_CC1E;
                TIM11->CCER &= ~TIM_CCER_CC1E;
            }
            break;
    }

    state[id].direction = dir;
    state[id].pwm_duty  = duty;
    state[id].enabled   = (dir != MOTOR_DIR_COAST);
}

void Motor_SetAll(int16_t pwm[MOTOR_COUNT])
{
    for (uint8_t i = 0; i < MOTOR_COUNT; i++) Motor_Set(i, pwm[i]);
}

void Motor_Brake(uint8_t id) { Motor_Coast(id); }
void Motor_BrakeAll(void)    { Motor_CoastAll(); }

void Motor_Coast(uint8_t id)
{
    if (id >= MOTOR_COUNT) return;
    s_current_pwm[id] = 0;  /* bypass ramp */

    switch (id) {
        case 0:
            TIM1->CCER &= ~(TIM_CCER_CC1E | TIM_CCER_CC1NE);
            TIM1->CCR1  = 0;
            break;
        case 1:
            TIM1->CCER &= ~(TIM_CCER_CC2E | TIM_CCER_CC2NE);
            TIM1->CCR2  = 0;
            break;
        case 2:
            TIM1->CCER &= ~(TIM_CCER_CC3E | TIM_CCER_CC3NE);
            TIM1->CCR3  = 0;
            break;
        case 3:
            /* FIX: clear CCR and disable output compare — guaranteed no pulses */
            TIM10->CCR1  = 0;
            TIM11->CCR1  = 0;
            TIM10->CCER &= ~TIM_CCER_CC1E;
            TIM11->CCER &= ~TIM_CCER_CC1E;
            break;
    }

    state[id].direction = MOTOR_DIR_COAST;
    state[id].pwm_duty  = 0;
    state[id].enabled   = false;
}

void Motor_CoastAll(void)
{
    for (uint8_t i = 0; i < MOTOR_COUNT; i++) Motor_Coast(i);
}

void Motor_EmergencyStop(void)
{
    Motor_CoastAll();
}

MotorState_t Motor_GetState(uint8_t id)
{
    if (id >= MOTOR_COUNT) {
        MotorState_t safe = {MOTOR_DIR_COAST, 0, false};
        return safe;
    }
    return state[id];
}
