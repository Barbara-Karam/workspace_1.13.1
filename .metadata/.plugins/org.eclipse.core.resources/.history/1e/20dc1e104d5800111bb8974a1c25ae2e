#include "main.h"
#include "tim.h"
#include "gpio.h"
#include "usart.h"
#include "motor_control.h"
#include "encoder.h"
#include "control_loop.h"
#include "comm.h"
#include <stdio.h>

void SystemClock_Config(void);

int main(void)
{
    HAL_Init();
    SystemClock_Config();

    MX_GPIO_Init();
    MX_TIM1_Init();
    MX_TIM2_Init();
    MX_TIM3_Init();
    MX_TIM4_Init();
    MX_TIM5_Init();
    MX_TIM10_Init();
    // make sure MX_TIM11_Init() is defined in your auto-generated tim.h/tim.c
    // MX_TIM11_Init();
    MX_USART2_UART_Init();

    // init rpod modules
    Encoder_Init();
    Motor_Init();
    ControlLoop_Init();
    Comm_Init();

    HAL_Delay(100);

    // fast blink to show firmware is alive
    for (int i = 0; i < 6; i++) {
        HAL_GPIO_TogglePin(STATUS_LED_GPIO_Port, STATUS_LED_Pin);
        HAL_Delay(100);
    }

    uint32_t last_telemetry_ms = 0;
    char tx_buf[128];

    // enable the control loop (starts PID if you are sending targets)
    ControlLoop_Enable();

    while (1)
    {
        uint32_t now = HAL_GetTick();

        // process any incoming jetson commands
        Comm_ProcessRx();

        // send high-speed binary feedback frame when PID updates
        if (g_ctrl.feedback_ready) {
            Comm_TransmitFeedback();
        }

        // string telemetry for serial monitor debugging @ 10Hz
        if ((now - last_telemetry_ms) >= 100) {
            last_telemetry_ms = now;

            // $TEL, rpm1, rpm2, rpm3, rpm4, pwm1, pwm2, pwm3, pwm4
            int len = snprintf(tx_buf, sizeof(tx_buf), "$TEL,%d,%d,%d,%d,%d,%d,%d,%d\r\n",
                               (int)Encoder_GetRPM(0),
                               (int)Encoder_GetRPM(1),
                               (int)Encoder_GetRPM(2),
                               (int)Encoder_GetRPM(3),
                               (int)Motor_GetState(0).pwm_duty,
                               (int)Motor_GetState(1).pwm_duty,
                               (int)Motor_GetState(2).pwm_duty,
                               (int)Motor_GetState(3).pwm_duty);

            HAL_UART_Transmit(&huart2, (uint8_t*)tx_buf, len, 10);
        }

        // 1Hz heartbeat led
        HAL_GPIO_WritePin(STATUS_LED_GPIO_Port, STATUS_LED_Pin,
            (now % 1000) < 500 ? GPIO_PIN_RESET : GPIO_PIN_SET);
    }
}

