#ifndef COMM_H
#define COMM_H

#include "stm32f4xx_hal.h"
#include <stdint.h>

// ─── Frame Format ─────────────────────────────────────────────────────────
// [0xAA][0x55][0xA5][TYPE:1][LEN:1][PAYLOAD:N][CRC8:1]
// 3-byte sync dramatically reduces false syncs inside binary payload data.
// False sync probability: ~1/16M per byte vs ~1/65K with 2-byte sync.
#define COMM_SYNC1              0xAA
#define COMM_SYNC2              0x55
#define COMM_SYNC3              0xA5   // ← new third sync byte
#define COMM_RX_BUF_SIZE        64
#define COMM_TX_BUF_SIZE        64     // Motor FB frame = 44 bytes total
// Maximum payload that fits: buffer minus 3 sync + type + len + crc (6 bytes overhead)
#define COMM_MAX_PAYLOAD    (COMM_TX_BUF_SIZE - 6u)   // = 58 bytes

// ─── Comm Watchdog ─────────────────────────────────────────────────────────
// If no valid frame is received within this window, ControlLoop_Run() forces
// a safe stop every tick until a valid frame arrives again. This protects
// against the host disconnecting, a cable fault, or frames being corrupted
// (e.g. by PWM switching noise on the UART lines while all motors are
// driving) and silently dropped by the CRC check — in all of those cases a
// graceful "stop" command may simply never arrive, so the firmware cannot
// rely on receiving one.
#define COMM_WATCHDOG_TIMEOUT_MS   300u

// Tick (HAL_GetTick()) of the last frame that passed sync+CRC validation,
// regardless of message type. Written only from Comm_ParseFrame(). Single
// aligned 32-bit store/load, safe to read from ISR context without a
// critical section.
extern volatile uint32_t g_comm_last_rx_tick;

// ─── Message Types ─────────────────────────────────────────────────────────
typedef enum {
    MSG_CONTROL_CMD = 0x01,   // Host → STM32: velocity targets
    MSG_ACTUATOR_FB = 0x02,   // STM32 → Host: motor feedback
    MSG_HEARTBEAT   = 0x03,   // Bidirectional: keep-alive
    MSG_ESTOP       = 0x04,   // Host → STM32: emergency stop
} MsgType_t;

// ─── Payload Structs ────────────────────────────────────────────────────────

typedef struct __attribute__((packed)) {
    int16_t vel_rpm10[4];   // Target RPM × 10
    uint8_t mode;           // 0=velocity PID, 1=open-loop PWM
} ControlCmd_t;             // 9 bytes

typedef struct __attribute__((packed)) {
    int16_t  vel_rpm10[4];  // Measured RPM × 10
    int32_t  enc_count[4];  // Absolute encoder counts
    int16_t  pwm_out[4];    // Applied PWM
    uint32_t timestamp_ms;  // HAL_GetTick()
    uint8_t  sys_status;    // Bit0: IMU OK, Bit1: WARN (comm watchdog tripped), Bit2: FAULT (e-stop latched)
} ActuatorFB_t;             // 37 bytes

// ─── API ────────────────────────────────────────────────────────────────────
void Comm_Init(void);
void Comm_ProcessRx(void);
void Comm_TransmitFeedback(void);
void HAL_UARTEx_RxEventCallback(UART_HandleTypeDef *huart, uint16_t size);

// Returns 1 if a valid frame has been received within COMM_WATCHDOG_TIMEOUT_MS,
// 0 otherwise. Safe to call from ISR context (TIM9 control loop).
uint8_t Comm_LinkOk(void);

#endif
