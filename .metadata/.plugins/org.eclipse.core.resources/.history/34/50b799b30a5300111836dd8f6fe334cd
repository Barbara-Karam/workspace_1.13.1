/**
  * @brief  The application entry point.
  * @retval int
  */
int main(void)
{

  /* USER CODE BEGIN 1 */

  /* USER CODE END 1 */

  /* MCU Configuration--------------------------------------------------------*/

  /* Reset of all peripherals, Initializes the Flash interface and the Systick. */
  HAL_Init();

  /* USER CODE BEGIN Init */

  /* USER CODE END Init */

  /* Configure the system clock */
  SystemClock_Config();

  /* USER CODE BEGIN SysInit */

  /* USER CODE END SysInit */

  /* Initialize all configured peripherals */
  MX_GPIO_Init();

  // NOTE: If the LED rapid-blinks infinitely on startup, comment these
  // two lines out one at a time to find out which one is crashing the board.
  MX_I2C1_Init();
  MX_USART2_Init();

  /* USER CODE BEGIN 2 */


    // Normal Startup Sequence: Blink 3 times
    for (int i = 0; i < 3; i++)
    {
      HAL_GPIO_TogglePin(GPIOC, GPIO_PIN_13);
      HAL_Delay(500);
      HAL_GPIO_TogglePin(GPIOC, GPIO_PIN_13);
      HAL_Delay(500);
    }

    // --- WAKE UP MPU6050 IMU ---
    uint8_t Data = 0x00;
    HAL_I2C_Mem_Write(&hi2c1, 0xD0, 0x6B, 1, &Data, 1, 1000);

    // --- CALIBRATE GYROSCOPE ---
    // Leave the IMU completely flat and still during this!
    uint8_t Cal_Data[6];
    for (int i = 0; i < 500; i++)
    {
        HAL_I2C_Mem_Read(&hi2c1, 0xD0, 0x43, 1, Cal_Data, 6, 1000);
        Gx_cal += (int16_t)(Cal_Data[0] << 8 | Cal_Data[1]);
        Gy_cal += (int16_t)(Cal_Data[2] << 8 | Cal_Data[3]);
        Gz_cal += (int16_t)(Cal_Data[4] << 8 | Cal_Data[5]);
        HAL_Delay(3); // Small delay between readings
    }

    // Divide by 500 to get the average offset
    Gx_cal /= 500.0;
    Gy_cal /= 500.0;
    Gz_cal /= 500.0;

    /* USER CODE END 2 */

    /* Infinite loop */
      /* USER CODE BEGIN WHILE */
      while (1)
      {
        /* USER CODE END WHILE */

        /* USER CODE BEGIN 3 */
        uint8_t Rec_Data[14];

        // Read 14 bytes starting from register 0x3B (ACCEL_XOUT_H)
        HAL_I2C_Mem_Read(&hi2c1, 0xD0, 0x3B, 1, Rec_Data, 14, 1000);

        // 1. Combine Raw Bytes
        Accel_X_RAW = (int16_t)(Rec_Data[0] << 8 | Rec_Data[1]);
        Accel_Y_RAW = (int16_t)(Rec_Data[2] << 8 | Rec_Data[3]);
        Accel_Z_RAW = (int16_t)(Rec_Data[4] << 8 | Rec_Data[5]);

        Gyro_X_RAW = (int16_t)(Rec_Data[8] << 8 | Rec_Data[9]);
        Gyro_Y_RAW = (int16_t)(Rec_Data[10] << 8 | Rec_Data[11]);
        Gyro_Z_RAW = (int16_t)(Rec_Data[12] << 8 | Rec_Data[13]);

        // 2. Convert Accelerometer to G-Force
        Ax = Accel_X_RAW / 16384.0;
        Ay = Accel_Y_RAW / 16384.0;
        Az = Accel_Z_RAW / 16384.0;

        // 3. Subtract Offset and Convert Gyroscope to Degrees/Second
        Gx = (Gyro_X_RAW - Gx_cal) / 131.0;
        Gy = (Gyro_Y_RAW - Gy_cal) / 131.0;
        Gz = (Gyro_Z_RAW - Gz_cal) / 131.0;

        HAL_Delay(50); // Refresh rate for Live Expressions
      }
      /* USER CODE END 3 */
}

