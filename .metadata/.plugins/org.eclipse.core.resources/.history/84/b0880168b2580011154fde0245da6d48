/** Configure pins as
        * Analog
        * Input
        * Output
        * EVENT_OUT
        * EXTI
*/
void MX_GPIO_Init(void)
{
    GPIO_InitTypeDef GPIO_InitStruct = {0};

    /* Clock enable — GPIOB needed for PB13/14/15 TIM1 complementary,
       but those are handled by HAL_TIM_MspPostInit.
       GPIOC for the status LED is all we configure here. */
    __HAL_RCC_GPIOC_CLK_ENABLE();
    __HAL_RCC_GPIOH_CLK_ENABLE();
    __HAL_RCC_GPIOA_CLK_ENABLE();
    __HAL_RCC_GPIOB_CLK_ENABLE();

    /* Status LED — PC13, active LOW */
    HAL_GPIO_WritePin(STATUS_LED_GPIO_Port, STATUS_LED_Pin, GPIO_PIN_RESET);

    GPIO_InitStruct.Pin   = STATUS_LED_Pin;
    GPIO_InitStruct.Mode  = GPIO_MODE_OUTPUT_PP;
    GPIO_InitStruct.Pull  = GPIO_NOPULL;
    GPIO_InitStruct.Speed = GPIO_SPEED_FREQ_LOW;
    HAL_GPIO_Init(STATUS_LED_GPIO_Port, &GPIO_InitStruct);

    /* ALL motor EN and direction pins are either:
     *   - Hardwired to 5V externally (EN pins) — do NOT touch from STM32
     *   - Configured as timer AF in HAL_TIM_MspPostInit (PWM pins)
     * No GPIO_Output configuration here — that was the conflict. */
}

