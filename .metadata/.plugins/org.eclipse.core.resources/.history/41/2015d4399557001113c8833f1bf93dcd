/* USER CODE BEGIN Header */
/**
  ******************************************************************************
  * @file    main.c
  * @brief   Black Pill — Minimal IMU + Motor1 + Encoder1
  *          NO module calls that might not exist.
  *          Raw register reads only for encoder + motor.
  *
  *  Live Expressions:
  *    imu_ok
  *    imu_data.accel_x
  *    imu_data.accel_z
  *    found_addr          ← must be 104 (0x68)
  *    enc_count           ← raw TIM2 counter
  *    motor1_pwm          ← what we wrote to TIM1 CCR1
  ******************************************************************************
  */
/* USER CODE END Header */

#include "main.h"
#include "i2c.h"
#include "tim.h"
#include "gpio.h"
#include "imu.h"

/* ── Globals — all volatile so debugger always sees them ────────────── */
IMUData_t        imu_data;
uint8_t          imu_ok     = 0;
uint8_t          found_addr = 0;
volatile int32_t enc_count  = 0;
volatile int16_t motor1_pwm = 0;
volatile uint32_t sanity = 0xDEADBEEF;

/* ── PWM test value: 1000 out of 4199 max (~24% duty) ──────────────── */
#define TEST_PWM   1000

void SystemClock_Config(void);

/* ── Minimal motor helpers — no motor_control.c needed ─────────────── */
static void motor1_forward(uint16_t pwm)
{
    TIM1->CCR1 = pwm;
    HAL_GPIO_WritePin(GPIOB, GPIO_PIN_12, GPIO_PIN_SET);    /* R_EN = 1 */
    HAL_GPIO_WritePin(GPIOB, GPIO_PIN_13, GPIO_PIN_RESET);  /* L_EN = 0 */
}

static void motor1_coast(void)
{
    TIM1->CCR1 = 0;
    HAL_GPIO_WritePin(GPIOB, GPIO_PIN_12, GPIO_PIN_RESET);
    HAL_GPIO_WritePin(GPIOB, GPIO_PIN_13, GPIO_PIN_RESET);
}

int main(void)
{
    HAL_Init();
    SystemClock_Config();
    MX_GPIO_Init();
    MX_I2C1_Init();
    MX_TIM1_Init();   /* Motor1 PWM */
    MX_TIM2_Init();   /* Encoder1  */

    HAL_Delay(300);

    /* ── Start TIM1 PWM channel 1 (Motor1) ─────────────────────────── */
    HAL_TIM_PWM_Start(&htim1, TIM_CHANNEL_1);
    motor1_coast();   /* safe start */

    /* ── Start TIM2 encoder mode ────────────────────────────────────── */
    HAL_TIM_Encoder_Start(&htim2, TIM_CHANNEL_ALL);

    /* ── I2C scan ───────────────────────────────────────────────────── */
    for (uint8_t addr = 1; addr < 128; addr++) {
        if (HAL_I2C_IsDeviceReady(&hi2c1,
                (uint16_t)(addr << 1), 2, 10) == HAL_OK) {
            found_addr = addr;
        }
    }

    /* ── IMU Init ───────────────────────────────────────────────────── */
    if (found_addr == 0x68) {
        if (IMU_Init() == HAL_OK) {
            imu_ok = 1;
            for (int i = 0; i < 6; i++) {
                HAL_GPIO_TogglePin(STATUS_LED_GPIO_Port, STATUS_LED_Pin);
                HAL_Delay(100);
            }
        }
    }

    /* ── Motor test timing ──────────────────────────────────────────── */
    uint32_t last_imu_ms    = 0;
    uint32_t motor_start_ms = HAL_GetTick();
    uint8_t  motor_on       = 1;

    motor1_forward(TEST_PWM);
    motor1_pwm = TEST_PWM;

    /* ── Main Loop ──────────────────────────────────────────────────── */
    while (1)
    {
        uint32_t now = HAL_GetTick();

        /* ── IMU @ 50 Hz ──────────────────────────────────────────── */
        if ((now - last_imu_ms) >= 20)
        {
            last_imu_ms = now;
            if (imu_ok) {
                IMUData_t local;
                if (IMU_Read(&local) == HAL_OK) {
                    __disable_irq();
                    imu_data = local;
                    __enable_irq();
                }
            }
        }

        /* ── Encoder: just read TIM2 counter directly ─────────────── */
        enc_count = (int32_t)(int16_t)TIM2->CNT;
        /* int16_t cast handles signed wrap on 16-bit overflow
           TIM2 is 32-bit so remove the int16_t cast if you configured
           TIM2 period as 0xFFFFFFFF in .ioc */

        /* ── Motor run 3s / coast 2s ──────────────────────────────── */
        if (motor_on && (now - motor_start_ms) >= 3000) {
            motor1_coast();
            motor1_pwm   = 0;
            motor_on     = 0;
            motor_start_ms = now;
        }
        else if (!motor_on && (now - motor_start_ms) >= 2000) {
            motor1_forward(TEST_PWM);
            motor1_pwm   = TEST_PWM;
            motor_on     = 1;
            motor_start_ms = now;
        }

        /* ── Heartbeat LED ────────────────────────────────────────── */
        HAL_GPIO_WritePin(STATUS_LED_GPIO_Port, STATUS_LED_Pin,
            (now % 1000) < 500 ? GPIO_PIN_RESET : GPIO_PIN_SET);

        HAL_Delay(5);
    }
}

void SystemClock_Config(void)
{
    RCC_OscInitTypeDef RCC_OscInitStruct = {0};
    RCC_ClkInitTypeDef RCC_ClkInitStruct = {0};

    __HAL_RCC_PWR_CLK_ENABLE();
    __HAL_PWR_VOLTAGESCALING_CONFIG(PWR_REGULATOR_VOLTAGE_SCALE2);

    RCC_OscInitStruct.OscillatorType  = RCC_OSCILLATORTYPE_HSE;
    RCC_OscInitStruct.HSEState        = RCC_HSE_ON;
    RCC_OscInitStruct.PLL.PLLState    = RCC_PLL_ON;
    RCC_OscInitStruct.PLL.PLLSource   = RCC_PLLSOURCE_HSE;
    RCC_OscInitStruct.PLL.PLLM        = 25;
    RCC_OscInitStruct.PLL.PLLN        = 168;
    RCC_OscInitStruct.PLL.PLLP        = RCC_PLLP_DIV2;
    RCC_OscInitStruct.PLL.PLLQ        = 4;
    if (HAL_RCC_OscConfig(&RCC_OscInitStruct) != HAL_OK) Error_Handler();

    RCC_ClkInitStruct.ClockType       = RCC_CLOCKTYPE_HCLK  | RCC_CLOCKTYPE_SYSCLK
                                      | RCC_CLOCKTYPE_PCLK1 | RCC_CLOCKTYPE_PCLK2;
    RCC_ClkInitStruct.SYSCLKSource    = RCC_SYSCLKSOURCE_PLLCLK;
    RCC_ClkInitStruct.AHBCLKDivider   = RCC_SYSCLK_DIV1;
    RCC_ClkInitStruct.APB1CLKDivider  = RCC_HCLK_DIV2;
    RCC_ClkInitStruct.APB2CLKDivider  = RCC_HCLK_DIV1;
    if (HAL_RCC_ClockConfig(&RCC_ClkInitStruct, FLASH_LATENCY_2) != HAL_OK) Error_Handler();
}

void Error_Handler(void)
{
    __disable_irq();
    while (1) {}
}
