#include "main.h"
#include "tim.h"
#include "gpio.h"
#include "usart.h"
#include "motor_control.h"
#include "pid.h"
#include <stdio.h>
#include <string.h>
#include <stdint.h>

#define TEST_PWM            2000
#define TEST_RUN_MS         3000
#define TEST_COAST_MS       1000

#define MOTOR_COUNT         4
#define ENCODER_CPR         1320.0f
#define ENC_DT_MS           20

volatile int16_t  g_pwm[MOTOR_COUNT]  = {0};
volatile int32_t  g_enc[MOTOR_COUNT]  = {0};
volatile int16_t  g_rpm[MOTOR_COUNT]  = {0};
volatile uint8_t  motor_state         = 0;

static uint32_t s_enc_raw_prev[MOTOR_COUNT] = {0};
static const uint8_t s_is_32bit[MOTOR_COUNT] = {1, 0, 0, 1};
static TIM_HandleTypeDef * const s_enc_tim[MOTOR_COUNT] = {
    &htim2, &htim3, &htim4, &htim5
};

void SystemClock_Config(void);

static void encoder_update(void)
{
    for (uint8_t i = 0; i < MOTOR_COUNT; i++) {
        uint32_t raw   = __HAL_TIM_GET_COUNTER(s_enc_tim[i]);
        int32_t  delta;

        if (s_is_32bit[i]) {
            delta = (int32_t)(raw - s_enc_raw_prev[i]);
        } else {
            delta = (int32_t)(int16_t)((uint16_t)raw - (uint16_t)s_enc_raw_prev[i]);
        }

        s_enc_raw_prev[i]  = raw;
        g_enc[i]          += delta;

        float rpm   = ((float)delta / ENCODER_CPR) / (ENC_DT_MS / 1000.0f) * 60.0f;
        g_rpm[i]    = (int16_t)(rpm * 10.0f);
    }
}

static void run_motor(uint8_t id, int16_t pwm)
{
    Motor_Set(id, pwm);
    g_pwm[id] = pwm;
}

static void run_all(int16_t pwm)
{
    for (uint8_t i = 0; i < MOTOR_COUNT; i++) run_motor(i, pwm);
}

static void coast_all_update(void)
{
    Motor_CoastAll();
    for (uint8_t i = 0; i < MOTOR_COUNT; i++) g_pwm[i] = 0;
}

static void apply_state(uint8_t s)
{
    coast_all_update();
    switch (s) {
        case 0: run_motor(0, TEST_PWM);  break;
        case 1: break;
        case 2: run_motor(1, TEST_PWM);  break;
        case 3: break;
        case 4: run_motor(2, TEST_PWM);  break;
        case 5: break;
        case 6: run_motor(3, TEST_PWM);  break;
        case 7: break;
        case 8: run_all(TEST_PWM);       break;
        case 9: break;
    }
}

static uint32_t state_duration(uint8_t s)
{
    return (s % 2 == 0) ? TEST_RUN_MS : TEST_COAST_MS;
}

int main(void)
{
    HAL_Init();
    SystemClock_Config();

    MX_GPIO_Init();
    MX_TIM1_Init();
    MX_TIM2_Init();
    MX_TIM3_Init();
    MX_TIM4_Init();
    MX_TIM5_Init();
    MX_TIM10_Init();
    MX_TIM11_Init();
    MX_USART2_UART_Init();

    HAL_Delay(200);

    Motor_Init();

    HAL_TIM_Encoder_Start(&htim2, TIM_CHANNEL_ALL);
    HAL_TIM_Encoder_Start(&htim3, TIM_CHANNEL_ALL);
    HAL_TIM_Encoder_Start(&htim4, TIM_CHANNEL_ALL);
    HAL_TIM_Encoder_Start(&htim5, TIM_CHANNEL_ALL);

    for (uint8_t i = 0; i < MOTOR_COUNT; i++) {
        s_enc_raw_prev[i] = __HAL_TIM_GET_COUNTER(s_enc_tim[i]);
        g_enc[i]          = 0;
    }

    for (int i = 0; i < 8; i++) {
        HAL_GPIO_TogglePin(STATUS_LED_GPIO_Port, STATUS_LED_Pin);
        HAL_Delay(100);
    }

    uint32_t state_tick_ms = HAL_GetTick();
    uint32_t enc_tick_ms   = HAL_GetTick();
    uint32_t tel_tick_ms   = HAL_GetTick();
    char     tx_buf[128];

    motor_state = 0;
    apply_state(0);

    while (1)
    {
        uint32_t now = HAL_GetTick();

        if ((now - enc_tick_ms) >= ENC_DT_MS)
        {
            enc_tick_ms = now;
            encoder_update();
        }

        if ((now - state_tick_ms) >= state_duration(motor_state))
        {
            state_tick_ms = now;
            motor_state   = (motor_state + 1) % 10;
            apply_state(motor_state);
        }

        if ((now - tel_tick_ms) >= 100)
        {
            tel_tick_ms = now;
            int len = snprintf(tx_buf, sizeof(tx_buf),
                "$TEL,%d,%d,%d,%d,%d,%d,%d,%d,%d\r\n",
                g_rpm[0], g_rpm[1], g_rpm[2], g_rpm[3],
                g_pwm[0], g_pwm[1], g_pwm[2], g_pwm[3],
                motor_state);
            HAL_UART_Transmit(&huart2, (uint8_t*)tx_buf, len, 10);
        }

        HAL_GPIO_WritePin(STATUS_LED_GPIO_Port, STATUS_LED_Pin,
            (now % 1000) < 500 ? GPIO_PIN_RESET : GPIO_PIN_SET);
    }
}

void SystemClock_Config(void)
{
    RCC_OscInitTypeDef RCC_OscInitStruct = {0};
    RCC_ClkInitTypeDef RCC_ClkInitStruct = {0};

    __HAL_RCC_PWR_CLK_ENABLE();
    __HAL_PWR_VOLTAGESCALING_CONFIG(PWR_REGULATOR_VOLTAGE_SCALE2);

    RCC_OscInitStruct.OscillatorType = RCC_OSCILLATORTYPE_HSE;
    RCC_OscInitStruct.HSEState       = RCC_HSE_ON;
    RCC_OscInitStruct.PLL.PLLState   = RCC_PLL_ON;
    RCC_OscInitStruct.PLL.PLLSource  = RCC_PLLSOURCE_HSE;
    RCC_OscInitStruct.PLL.PLLM       = 25;
    RCC_OscInitStruct.PLL.PLLN       = 336;
    RCC_OscInitStruct.PLL.PLLP       = RCC_PLLP_DIV4;
    RCC_OscInitStruct.PLL.PLLQ       = 4;
    if (HAL_RCC_OscConfig(&RCC_OscInitStruct) != HAL_OK) Error_Handler();

    RCC_ClkInitStruct.ClockType      = RCC_CLOCKTYPE_HCLK  | RCC_CLOCKTYPE_SYSCLK
                                     | RCC_CLOCKTYPE_PCLK1 | RCC_CLOCKTYPE_PCLK2;
    RCC_ClkInitStruct.SYSCLKSource   = RCC_SYSCLKSOURCE_PLLCLK;
    RCC_ClkInitStruct.AHBCLKDivider  = RCC_SYSCLK_DIV1;
    RCC_ClkInitStruct.APB1CLKDivider = RCC_HCLK_DIV2;
    RCC_ClkInitStruct.APB2CLKDivider = RCC_HCLK_DIV1;
    if (HAL_RCC_ClockConfig(&RCC_ClkInitStruct, FLASH_LATENCY_2) != HAL_OK) Error_Handler();
}

void Error_Handler(void)
{
    __disable_irq();
    while (1) {}
}
