/**
  ******************************************************************************
  * @file           : main.c
  * @brief          : 4-Motor Control — No IMU — UART Telemetry
  *
  * WIRING:
  *   Motor 0: PA8  (TIM1_CH1)  = RPWM,  PB13 (TIM1_CH1N) = LPWM
  *   Motor 1: PA9  (TIM1_CH2)  = RPWM,  PB14 (TIM1_CH2N) = LPWM
  *   Motor 2: PA10 (TIM1_CH3)  = RPWM,  PB15 (TIM1_CH3N) = LPWM
  *   Motor 3: PB8  (TIM10_CH1) = RPWM,  PB9  (TIM11_CH1) = LPWM
  *   All 8 EN pins hardwired HIGH
  *
  *   Encoders:
  *   PA5/PB3 → TIM2 (Motor 0, 32-bit)
  *   PA6/PA7 → TIM3 (Motor 1, 16-bit)
  *   PB6/PB7 → TIM4 (Motor 2, 16-bit)
  *   PA0/PA1 → TIM5 (Motor 3, 32-bit)
  *
  *   PA2 → UART TX → Jetson RX
  *
  * CONTROL LOOP: 100 Hz via HAL_GetTick() in superloop
  *
  * TELEMETRY @ 10 Hz ($TEL):
  *   rpm0,rpm1,rpm2,rpm3,pwm0,pwm1,pwm2,pwm3
  *   RPM × 10 as integers (e.g. 3000 = 300.0 RPM)
  *
  * LIVE EXPRESSIONS:
  *   g_rpm[0..3]      — measured RPM × 10
  *   g_pwm[0..3]      — applied PWM duty (signed)
  *   g_enc[0..3]      — absolute encoder counts
  *   motor_enabled    — 1 = PID running
  ******************************************************************************
  */
