/* ==============================================================================
 * RPOD CHASER - 4-MOTOR LOW LEVEL CONTROLLER
 * Hardware: STM32F401RCT6 (Black Pill) + 4x BTS7960 Drivers
 * Clock Setup: 84 MHz (HSE 25MHz -> PLL M:25, N:336, P:DIV4)
 * PWM Freq: 1 kHz (Prescaler: 19, Period: 4199) - Bypasses RC filter issue
 * ==============================================================================
 * [MOTOR WIRING - BTS7960]
 * CRITICAL DRIVER LOGIC:
 * - VCC (Logic Header) -> 3.3V on STM32
 * - R_EN & L_EN        -> 3.3V on STM32 (Always enabled)
 * - GND                -> Common GND (STM32 + 12V Supply)
 * - B+ / B-            -> 12V Power Supply
 *
 * Motor 0 (TIM1)     -> RPWM: PA8  (CH1)    | LPWM: PB13 (CH1N)
 * Motor 1 (TIM1)     -> RPWM: PA9  (CH2)    | LPWM: PB14 (CH2N)
 * Motor 2 (TIM1)     -> RPWM: PA10 (CH3)    | LPWM: PB15 (CH3N)
 * Motor 3 (TIM10/11) -> RPWM: PB8  (T10_C1) | LPWM: PB9  (T11_C1)
 * ------------------------------------------------------------------------------
 * [ENCODER WIRING] (Max Frequency, Prescaler = 0)
 * Motor 0 (TIM2) -> CHA: PA5  | CHB: PB3
 * Motor 1 (TIM3) -> CHA: PA6  | CHB: PA7  *(Note: May be PC7 based on CubeMX remap)
 * Motor 2 (TIM4) -> CHA: PB6  | CHB: PB7
 * Motor 3 (TIM5) -> CHA: PA0  | CHB: PA1
 * ------------------------------------------------------------------------------
 * [COMMUNICATIONS & MISC]
 * UART2 (Jetson) -> TX: PA2   | RX: PA3
 * Status LED     -> PC13 (Active Low)
 * ==============================================================================
 */

#include "main.h"
#include "tim.h"
#include "usart.h"
#include "gpio.h"
#include <stdio.h>
#include <string.h>

void SystemClock_Config(void);

/* ── Encoder Tracking Variables ──────────────────────────────────────────── */
volatile int32_t  enc_abs[4]   = {0, 0, 0, 0};
volatile int32_t  enc_delta[4] = {0, 0, 0, 0};
uint32_t          last_raw[4]  = {0, 0, 0, 0};

/* ── UART Comms Variables ────────────────────────────────────────────────── */
uint8_t rx_byte;
char    rx_buffer[64];
uint8_t rx_index = 0;
volatile int16_t target_pwm[4] = {0, 0, 0, 0}; // Jetson commands live here
char    tx_buffer[128];

/* ── Safe Encoder Read Function ──────────────────────────────────────────── */
void Read_All_Encoders(void)
{
    uint32_t current_raw[4] = {TIM2->CNT, TIM3->CNT, TIM4->CNT, TIM5->CNT};

    enc_delta[0] = (int32_t)(current_raw[0] - last_raw[0]);
    enc_delta[1] = (int16_t)(current_raw[1] - last_raw[1]);
    enc_delta[2] = (int16_t)(current_raw[2] - last_raw[2]);
    enc_delta[3] = (int32_t)(current_raw[3] - last_raw[3]);

    for(int i=0; i<4; i++) {
        enc_abs[i] += enc_delta[i];
        last_raw[i] = current_raw[i];
    }
}

/* ── Proven Motor Control Function ───────────────────────────────────────── */
void Set_Motor(uint8_t motor_id, int16_t speed)
{
    uint16_t pwm = (speed > 0) ? speed : -speed;
    if (pwm > 4199) pwm = 4199; // Cap at max timer period

    if (motor_id == 0) {
        if (speed > 0) { TIM1->CCER |= TIM_CCER_CC1E; TIM1->CCER &= ~TIM_CCER_CC1NE; TIM1->CCR1 = pwm; }
        else if (speed < 0) { TIM1->CCER &= ~TIM_CCER_CC1E; TIM1->CCER |= TIM_CCER_CC1NE; TIM1->CCR1 = pwm; }
        else { TIM1->CCER &= ~(TIM_CCER_CC1E | TIM_CCER_CC1NE); TIM1->CCR1 = 0; }
    } else if (motor_id == 1) {
        if (speed > 0) { TIM1->CCER |= TIM_CCER_CC2E; TIM1->CCER &= ~TIM_CCER_CC2NE; TIM1->CCR2 = pwm; }
        else if (speed < 0) { TIM1->CCER &= ~TIM_CCER_CC2E; TIM1->CCER |= TIM_CCER_CC2NE; TIM1->CCR2 = pwm; }
        else { TIM1->CCER &= ~(TIM_CCER_CC2E | TIM_CCER_CC2NE); TIM1->CCR2 = 0; }
    } else if (motor_id == 2) {
        if (speed > 0) { TIM1->CCER |= TIM_CCER_CC3E; TIM1->CCER &= ~TIM_CCER_CC3NE; TIM1->CCR3 = pwm; }
        else if (speed < 0) { TIM1->CCER &= ~TIM_CCER_CC3E; TIM1->CCER |= TIM_CCER_CC3NE; TIM1->CCR3 = pwm; }
        else { TIM1->CCER &= ~(TIM_CCER_CC3E | TIM_CCER_CC3NE); TIM1->CCR3 = 0; }
    } else if (motor_id == 3) {
        if (speed > 0) { TIM10->CCR1 = pwm; TIM11->CCR1 = 0; }
        else if (speed < 0) { TIM10->CCR1 = 0; TIM11->CCR1 = pwm; }
        else { TIM10->CCR1 = 0; TIM11->CCR1 = 0; }
    }
}

/* ── UART Interrupt Callback (Parses Jetson Commands) ────────────────────── */
void HAL_UART_RxCpltCallback(UART_HandleTypeDef *huart)
{
    if (huart->Instance == USART2) {
        if (rx_byte == '\n' || rx_byte == '\r') {
            rx_buffer[rx_index] = '\0';

            /* If it's a command, extract the 4 PWM targets */
            if (strncmp(rx_buffer, "$CMD,", 5) == 0) {
                sscanf(rx_buffer, "$CMD,%hd,%hd,%hd,%hd",
                       &target_pwm[0], &target_pwm[1], &target_pwm[2], &target_pwm[3]);
            }
            rx_index = 0;
        } else {
            if (rx_index < 63) rx_buffer[rx_index++] = rx_byte;
        }
        /* Re-arm the interrupt to listen for the next byte */
        HAL_UART_Receive_IT(&huart2, &rx_byte, 1);
    }
}

int main(void)
{
    HAL_Init();
    SystemClock_Config();
    MX_GPIO_Init();
    MX_USART2_UART_Init();

    MX_TIM1_Init(); MX_TIM10_Init(); MX_TIM11_Init();
    MX_TIM2_Init(); MX_TIM3_Init(); MX_TIM4_Init(); MX_TIM5_Init();

    HAL_Delay(500);

    HAL_TIM_PWM_Start(&htim1, TIM_CHANNEL_1); HAL_TIMEx_PWMN_Start(&htim1, TIM_CHANNEL_1);
    HAL_TIM_PWM_Start(&htim1, TIM_CHANNEL_2); HAL_TIMEx_PWMN_Start(&htim1, TIM_CHANNEL_2);
    HAL_TIM_PWM_Start(&htim1, TIM_CHANNEL_3); HAL_TIMEx_PWMN_Start(&htim1, TIM_CHANNEL_3);
    __HAL_TIM_MOE_ENABLE(&htim1);
    HAL_TIM_PWM_Start(&htim10, TIM_CHANNEL_1); HAL_TIM_PWM_Start(&htim11, TIM_CHANNEL_1);

    HAL_TIM_Encoder_Start(&htim2, TIM_CHANNEL_ALL);
    HAL_TIM_Encoder_Start(&htim3, TIM_CHANNEL_ALL);
    HAL_TIM_Encoder_Start(&htim4, TIM_CHANNEL_ALL);
    HAL_TIM_Encoder_Start(&htim5, TIM_CHANNEL_ALL);

    /* Start listening on UART via Interrupts */
    HAL_UART_Receive_IT(&huart2, &rx_byte, 1);

    uint32_t last_loop_ms = HAL_GetTick();

    while (1)
    {
        uint32_t now = HAL_GetTick();

        /* Run control loop at exactly 50Hz (20ms) */
        if (now - last_loop_ms >= 20) {
            last_loop_ms = now;

            /* 1. Read the hardware */
            Read_All_Encoders();

            /* 2. Apply the latest target speeds from Jetson */
            Set_Motor(0, target_pwm[0]);
            Set_Motor(1, target_pwm[1]);
            Set_Motor(2, target_pwm[2]);
            Set_Motor(3, target_pwm[3]);

            /* 3. Send telemetry back to Jetson */
            int len = snprintf(tx_buffer, sizeof(tx_buffer), "$TEL,%ld,%ld,%ld,%ld\r\n",
                               enc_abs[0], enc_abs[1], enc_abs[2], enc_abs[3]);
            HAL_UART_Transmit(&huart2, (uint8_t*)tx_buffer, len, 10);
        }

        HAL_GPIO_WritePin(STATUS_LED_GPIO_Port, STATUS_LED_Pin, (now % 1000) < 500 ? GPIO_PIN_RESET : GPIO_PIN_SET);
    }
}
