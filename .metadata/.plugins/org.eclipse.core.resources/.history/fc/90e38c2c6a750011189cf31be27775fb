#ifndef CONTROL_LOOP_H
#define CONTROL_LOOP_H

#include "pid.h"
#include <stdint.h>

#define CTRL_MOTOR_COUNT    4
#define CTRL_DT             0.01f
#define CTRL_RPM_MAX        35.0f
#define CTRL_PWM_MAX        4199.0f

#define PID_KP              80.0f
#define PID_KI              40.0f
#define PID_KD              0.0f
#define PID_OUT_LIMIT       CTRL_PWM_MAX

/* CHANGED: pid.c now uses conditional-integration anti-windup instead of a
   hard integrator clamp -- see the comment block in PID_Update(). That
   clamp used to be 800.0f, which (combined with P maxing out around 300 at
   full RPM error) capped sustained output at ~1100/4199 (~26% duty)
   regardless of commanded speed. That was the ceiling causing "motor speed
   barely changes when target is raised/lowered": the loop was pinned
   against this limit, not tracking the setpoint.

   integrator_limit is now only a hard safety backstop against unbounded
   float growth in edge cases (dt anomalies, gain retuning, etc.), not the
   everyday operating ceiling -- conditional integration in PID_Update()
   handles normal anti-windup. Set equal to PID_OUT_LIMIT so it never
   interferes with legitimate control authority; the actual output clamp
   in PID_Update() still bounds motor commands to +/-PID_OUT_LIMIT either
   way, so this cannot let output exceed the actuator's real range.        */
#define PID_INT_LIMIT       PID_OUT_LIMIT

/* ── Zero-target stall cutout ──────────────────────────────────────────
   Encoder quantization at 100 Hz / 1320 CPR means one count of noise reads
   as ~4.5 RPM. If measured_rpm lands inside that noise band while setpoint
   is exactly 0, PID error is ~0 and the integrator stops updating (does not
   unwind) -- it just freezes at whatever residual value it held, and that
   residual can still be above PWM_DEADBAND, driving the motor forever.
   This is a hard backstop independent of the PID math: once a motor has
   been commanded to 0 AND reads within CTRL_ZERO_RPM_EPS for
   CTRL_ZERO_STALL_TICKS consecutive control ticks, output is forced to
   zero and that motor's PID state is reset, regardless of what the
   integrator computed. This mechanism -- not the (now-relaxed) integrator
   clamp above -- is what prevents the original stale-windup-after-stop
   bug, so lifting the clamp does not reopen that issue.                   */
#define CTRL_ZERO_RPM_EPS       1.0f   /* > 1 encoder-count of RPM noise */
#define CTRL_ZERO_STALL_TICKS   5u     /* 5 ticks @ 100Hz = 50ms */

/* NEW: tight integrator ceiling used ONLY while setpoint_rpm[i] == 0, i.e.
   during the deceleration-to-stop transient before the stall cutout above
   has had time to trigger (up to CTRL_ZERO_STALL_TICKS ticks / 50ms).

   The conditional-integration anti-windup in pid.c intentionally allows the
   integrator to use the full +/-PID_OUT_LIMIT range so driving to a nonzero
   target isn't artificially capped. That's correct for tracking, but it also
   applies during this 50ms braking window: if the wheel is still spinning
   when setpoint drops to 0, error is large for a few ticks and the
   integrator can wind up hard enough to overshoot and actively drive the
   motor (often reversed) before the stall cutout fires -- i.e. the motor
   "stops, then starts running again" on its own after a zero command.

   Re-clamping to this much smaller limit every tick while setpoint==0
   (applied in ControlLoop_Run(), before calling PID_Update) bounds how much
   corrective torque the braking transient can ever apply, without touching
   the general-purpose anti-windup logic used for normal driving. Value
   matches the old global integrator_limit (800), which is known from prior
   tuning to be enough for gentle braking without kicking the motor.        */
#define CTRL_ZERO_BRAKE_INT_LIMIT   300.0f

/* ── Internal ISR-side state ─────────────────────────────────────────────
   Written exclusively from ControlLoop_Run() (TIM9 ISR, priority 3), except
   setpoint_rpm which is also written by ControlLoop_SetTarget() (called
   from the UART RX ISR, priority 1 -- higher priority, can preempt TIM9).
   Do NOT read these fields from mainline code — use ControlSnapshot_t instead.
   volatile is retained to prevent the compiler from caching registers across
   the ISR boundary, but volatile alone does NOT make multi-byte reads atomic.  */
typedef struct {
    float   setpoint_rpm[CTRL_MOTOR_COUNT];  /* written by mainline/UART ISR (under critical section for the PID_Reset path) */
    float   measured_rpm[CTRL_MOTOR_COUNT];  /* written by ISR only */
    float   output_pwm[CTRL_MOTOR_COUNT];    /* written by ISR only */
    PID_t   pid[CTRL_MOTOR_COUNT];
    uint8_t zero_tick_count[CTRL_MOTOR_COUNT]; /* consecutive ticks near-zero w/ zero setpoint; ISR-only */
    uint32_t tick_count;
    uint8_t  enabled;
    uint8_t  estop_latched;   /* set by MSG_ESTOP via ControlLoop_EmergencyLatch().
                                  Unlike the comm watchdog, this does NOT auto-clear when
                                  comms recover — it requires deliberate action (or reset),
                                  matching the intent of an emergency stop. */
    uint8_t  feedback_ready;   /* set by ISR, cleared by mainline under critical section */
} ControlLoop_t;

extern volatile ControlLoop_t g_ctrl;

/* ── Snapshot: safe mainline view of the last completed control tick ─────
   multi-byte float fields (measured_rpm, output_pwm) cannot be read
   atomically from a struct that is concurrently written by the ISR.  Mainline
   code must call ControlLoop_GetSnapshot() which copies the data inside a
   critical section.  Comm_TransmitFeedback() and any other non-ISR code that
   needs motor data must use this struct, never g_ctrl directly.             */
typedef struct {
    float    measured_rpm[CTRL_MOTOR_COUNT];
    float    output_pwm[CTRL_MOTOR_COUNT];
    uint32_t tick_count;
} ControlSnapshot_t;

/* Copy the last complete set of feedback fields atomically.
   Returns 1 if new data was available (feedback_ready was set), 0 otherwise.
   Clears feedback_ready on success so each snapshot is consumed once.       */
uint8_t ControlLoop_GetSnapshot(ControlSnapshot_t *out);

/* ── API ── */
void ControlLoop_Init(void);
void ControlLoop_Run(void);   /* call from TIM9 ISR only */
void ControlLoop_SetTarget(uint8_t id, float rpm);
void ControlLoop_SetAllTargets(float rpm[CTRL_MOTOR_COUNT]);
void ControlLoop_Enable(void);
void ControlLoop_Disable(void);

/* Latch an emergency stop. Forces enabled=0 and safe motor state every
   tick from within ControlLoop_Run(), and — critically — does NOT get
   cleared by the comm watchdog logic recovering. Only a reset (or a future
   explicit unlatch API, not currently exposed) clears it. */
void    ControlLoop_EmergencyLatch(void);
uint8_t ControlLoop_IsEstopLatched(void);

#endif /* CONTROL_LOOP_H */
