#include "main.h"
#include "tim.h"
#include "gpio.h"

void SystemClock_Config(void);

int main(void)
{
    HAL_Init();
    SystemClock_Config();
    MX_GPIO_Init();
    MX_TIM1_Init();

    HAL_Delay(500); // Let power stabilize

    /* 1. Start main channel (PA8) and complementary channel (PB13) */
    HAL_TIM_PWM_Start(&htim1, TIM_CHANNEL_1);
    HAL_TIMEx_PWMN_Start(&htim1, TIM_CHANNEL_1);

    /* 2. Enable Main Output for Advanced Timer (Crucial!) */
    __HAL_TIM_MOE_ENABLE(&htim1);

    while (1)
    {
        /* FORWARD: RPWM gets signal, LPWM is forced to 0V */
        TIM1->CCER |= TIM_CCER_CC1E;    // Enable PA8
        TIM1->CCER &= ~TIM_CCER_CC1NE;  // Disable PB13
        TIM1->CCR1 = 2000;              // ~50% Power

        HAL_GPIO_WritePin(STATUS_LED_GPIO_Port, STATUS_LED_Pin, GPIO_PIN_RESET);
        HAL_Delay(3000);

        /* COAST: Both pins forced to 0V */
        TIM1->CCER &= ~TIM_CCER_CC1E;   // Disable PA8
        TIM1->CCER &= ~TIM_CCER_CC1NE;  // Disable PB13
        TIM1->CCR1 = 0;                 // 0% Power

        HAL_GPIO_WritePin(STATUS_LED_GPIO_Port, STATUS_LED_Pin, GPIO_PIN_SET);
        HAL_Delay(3000);
    }
}
