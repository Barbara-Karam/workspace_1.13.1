/* USER CODE BEGIN Header */
/**
  ******************************************************************************
  * @file           : main.c
  * @brief          : 4-Motor Control — No IMU — UART Telemetry
  *
  * WIRING:
  *   Motor 0: PA8  (TIM1_CH1)  = RPWM,  PB13 (TIM1_CH1N) = LPWM
  *   Motor 1: PA9  (TIM1_CH2)  = RPWM,  PB14 (TIM1_CH2N) = LPWM
  *   Motor 2: PA10 (TIM1_CH3)  = RPWM,  PB15 (TIM1_CH3N) = LPWM
  *   Motor 3: PB8  (TIM10_CH1) = RPWM,  PB9  (TIM11_CH1) = LPWM
  *   All 8 EN pins hardwired HIGH
  *
  *   Encoders:
  *   PA5/PB3 → TIM2 (Motor 0, 32-bit)
  *   PA6/PA7 → TIM3 (Motor 1, 16-bit)
  *   PB6/PB7 → TIM4 (Motor 2, 16-bit)
  *   PA0/PA1 → TIM5 (Motor 3, 32-bit)
  *
  *   PA2 → UART TX → Jetson RX
  *
  * CONTROL LOOP: 100 Hz via HAL_GetTick() in superloop
  *
  * TELEMETRY @ 10 Hz ($TEL):
  *   rpm0,rpm1,rpm2,rpm3,pwm0,pwm1,pwm2,pwm3
  *   RPM × 10 as integers (e.g. 3000 = 300.0 RPM)
  *
  * LIVE EXPRESSIONS:
  *   g_rpm[0..3]      — measured RPM × 10
  *   g_pwm[0..3]      — applied PWM duty (signed)
  *   g_enc[0..3]      — absolute encoder counts
  *   motor_enabled    — 1 = PID running
  ******************************************************************************
  */
/* USER CODE END Header */

#include "main.h"
#include "tim.h"
#include "gpio.h"
#include "usart.h"
#include "motor_control.h"
#include "encoder.h"
#include "pid.h"
#include <stdio.h>
#include <string.h>
#include <stdint.h>

/* ── Constants ───────────────────────────────────────────────────────────── */
#define MOTOR_COUNT         4
#define CONTROL_HZ          100             /* Hz                           */
#define CONTROL_DT_MS       (1000 / CONTROL_HZ)   /* 10 ms                 */
#define TELEMETRY_HZ        10
#define TELEMETRY_DT_MS     (1000 / TELEMETRY_HZ) /* 100 ms                */

#define ENCODER_CPR         1320.0f         /* 11 PPR × 4 × 30:1 gear      */
#define RPM_MAX             300.0f
#define PWM_LIMIT           4199.0f
#define INT_LIMIT           2000.0f

/* PID gains — tune after verifying direction */
#define KP  2.0f
#define KI  8.0f
#define KD  0.05f

/* ── Live Expression globals ─────────────────────────────────────────────── */
volatile int16_t  g_rpm[MOTOR_COUNT]  = {0};   /* measured RPM × 10        */
volatile int16_t  g_pwm[MOTOR_COUNT]  = {0};   /* applied signed PWM       */
volatile int32_t  g_enc[MOTOR_COUNT]  = {0};   /* absolute encoder counts  */
volatile uint8_t  motor_enabled       = 0;     /* 1 = PID active           */

/* ── Internal state ──────────────────────────────────────────────────────── */
static float      s_setpoint[MOTOR_COUNT] = {0};   /* RPM targets          */
static PID_t      s_pid[MOTOR_COUNT];
static int32_t    s_enc_prev[MOTOR_COUNT] = {0};
static uint32_t   s_enc_raw_prev[MOTOR_COUNT] = {0};

/* Encoder timer handles — matches physical wiring */
static TIM_HandleTypeDef * const s_enc_tim[MOTOR_COUNT] = {
    &htim2,   /* Motor 0: PA5/PB3  32-bit */
    &htim3,   /* Motor 1: PA6/PA7  16-bit */
    &htim4,   /* Motor 2: PB6/PB7  16-bit */
    &htim5,   /* Motor 3: PA0/PA1  32-bit */
};
static const uint8_t s_is_32bit[MOTOR_COUNT] = {1, 0, 0, 1};

void SystemClock_Config(void);

/* ── Encoder helpers ─────────────────────────────────────────────────────── */
static void encoder_init(void)
{
    HAL_TIM_Encoder_Start(&htim2, TIM_CHANNEL_ALL);
    HAL_TIM_Encoder_Start(&htim3, TIM_CHANNEL_ALL);
    HAL_TIM_Encoder_Start(&htim4, TIM_CHANNEL_ALL);
    HAL_TIM_Encoder_Start(&htim5, TIM_CHANNEL_ALL);

    for (uint8_t i = 0; i < MOTOR_COUNT; i++) {
        s_enc_raw_prev[i] = __HAL_TIM_GET_COUNTER(s_enc_tim[i]);
        s_enc_prev[i]     = 0;
        g_enc[i]          = 0;
    }
}

/*
 * Returns RPM for motor `id` and updates g_enc[id].
 * Called every CONTROL_DT_MS = 10ms.
 */
static float encoder_get_rpm(uint8_t id)
{
    uint32_t raw = __HAL_TIM_GET_COUNTER(s_enc_tim[id]);
    int32_t  delta;

    if (s_is_32bit[id]) {
        delta = (int32_t)(raw - s_enc_raw_prev[id]);
    } else {
        delta = (int32_t)(int16_t)((uint16_t)raw
                                 - (uint16_t)s_enc_raw_prev[id]);
    }

    s_enc_raw_prev[id]  = raw;
    g_enc[id]          += delta;

    /* RPM = (delta / CPR / dt_s) × 60 */
    return ((float)delta / ENCODER_CPR) / (CONTROL_DT_MS / 1000.0f) * 60.0f;
}

/* ── Control loop (called every 10 ms from superloop) ───────────────────── */
static void control_loop_run(void)
{
    for (uint8_t i = 0; i < MOTOR_COUNT; i++) {
        float rpm = encoder_get_rpm(i);
        g_rpm[i]  = (int16_t)(rpm * 10.0f);

        if (motor_enabled) {
            float out = PID_Update(&s_pid[i],
                                   s_setpoint[i], rpm,
                                   CONTROL_DT_MS / 1000.0f);
            g_pwm[i] = (int16_t)out;
            Motor_Set(i, (int16_t)out);
        } else {
            g_pwm[i] = 0;
        }
    }
}

/* ── UART RX: minimal command parser ────────────────────────────────────── */
/*
 * Expected frame (binary, matching comm.h MSG_CONTROL_CMD):
 *   [0xAA][0x55][0xA5][0x01][9][rpm0_hi][rpm0_lo]...[rpm3_hi][rpm3_lo][mode][CRC]
 *
 * For the diagnostic phase a simpler ASCII command is also accepted:
 *   "SET,<rpm0>,<rpm1>,<rpm2>,<rpm3>\r\n"  (RPM as integers, e.g. SET,100,-50,0,200)
 *   "STOP\r\n"
 *   "GO\r\n"
 */
static uint8_t s_rx_byte;

static void uart_rx_process(char *line)
{
    int r0, r1, r2, r3;

    if (strncmp(line, "STOP", 4) == 0) {
        motor_enabled = 0;
        Motor_CoastAll();
        for (uint8_t i = 0; i < MOTOR_COUNT; i++) s_setpoint[i] = 0.0f;
    }
    else if (strncmp(line, "GO", 2) == 0) {
        for (uint8_t i = 0; i < MOTOR_COUNT; i++) PID_Reset(&s_pid[i]);
        motor_enabled = 1;
    }
    else if (sscanf(line, "SET,%d,%d,%d,%d", &r0, &r1, &r2, &r3) == 4) {
        /* Clamp and store RPM setpoints */
        float targets[4] = {(float)r0, (float)r1,
                             (float)r2, (float)r3};
        for (uint8_t i = 0; i < MOTOR_COUNT; i++) {
            if (targets[i] >  RPM_MAX) targets[i] =  RPM_MAX;
            if (targets[i] < -RPM_MAX) targets[i] = -RPM_MAX;
            s_setpoint[i] = targets[i];
        }
        if (!motor_enabled) {
            for (uint8_t i = 0; i < MOTOR_COUNT; i++) PID_Reset(&s_pid[i]);
            motor_enabled = 1;
        }
    }
}

/* ── Main ────────────────────────────────────────────────────────────────── */
int main(void)
{
    HAL_Init();
    SystemClock_Config();

    MX_GPIO_Init();
    MX_TIM1_Init();    /* Motor 0-2 PWM + complementary                    */
    MX_TIM2_Init();    /* Encoder 0 (32-bit)                               */
    MX_TIM3_Init();    /* Encoder 1 (16-bit)                               */
    MX_TIM4_Init();    /* Encoder 2 (16-bit)                               */
    MX_TIM5_Init();    /* Encoder 3 (32-bit)                               */
    MX_TIM10_Init();   /* Motor 3 RPWM                                     */
    MX_TIM11_Init();   /* Motor 3 LPWM                                     */
    MX_USART2_UART_Init();

    HAL_Delay(200);

    /* ── PIDs ────────────────────────────────────────────────────────── */
    for (uint8_t i = 0; i < MOTOR_COUNT; i++) {
        PID_Init(&s_pid[i], KP, KI, KD, PWM_LIMIT, INT_LIMIT);
    }

    /* ── Hardware start ──────────────────────────────────────────────── */
    Motor_Init();        /* starts all PWM channels, coasts all motors     */
    encoder_init();

    /* ── Status LED: 3 slow blinks = ready ──────────────────────────── */
    for (int i = 0; i < 6; i++) {
        HAL_GPIO_TogglePin(STATUS_LED_GPIO_Port, STATUS_LED_Pin);
        HAL_Delay(150);
    }

    /* ── Loop timing ─────────────────────────────────────────────────── */
    uint32_t last_ctrl_ms = HAL_GetTick();
    uint32_t last_tel_ms  = HAL_GetTick();

    /* ── UART line buffer ────────────────────────────────────────────── */
    char     rx_line[64];
    uint8_t  rx_idx  = 0;
    char     tx_buf[128];

    /* Start non-blocking single-byte RX */
        HAL_UART_Receive_IT(&huart2, &s_rx_byte, 1);

        /* ── QUICK TEST OVERRIDE ─────────────────────────────────────────── */
        /* Force the PID active and set a default target before UART connects */
        motor_enabled = 1;
        s_setpoint[0] = 50.0f;  /* 50 RPM on Motor 0 */
        // s_setpoint[1] = 50.0f;  /* Uncomment to test Motor 1 */
        // s_setpoint[2] = -50.0f; /* Uncomment to test Motor 2 */
        // s_setpoint[3] = -50.0f; /* Uncomment to test Motor 3 */

        /* ── Main loop ───────────────────────────────────────────────────── */
        while (1)
        {
            uint32_t now = HAL_GetTick();

        /* ── 100 Hz control tick ──────────────────────────────────────── */
        if ((now - last_ctrl_ms) >= CONTROL_DT_MS)
        {
            last_ctrl_ms = now;
            control_loop_run();
        }

        /* ── 10 Hz telemetry ──────────────────────────────────────────── */
        /*
         * Format: $TEL,rpm0,rpm1,rpm2,rpm3,pwm0,pwm1,pwm2,pwm3\r\n
         * RPM integers are × 10 (e.g. 3000 = 300.0 RPM)
         * PWM signed 0–4199
         */
        if ((now - last_tel_ms) >= TELEMETRY_DT_MS)
        {
            last_tel_ms = now;

            int len = snprintf(tx_buf, sizeof(tx_buf),
                "$TEL,%d,%d,%d,%d,%d,%d,%d,%d\r\n",
                g_rpm[0], g_rpm[1], g_rpm[2], g_rpm[3],
                g_pwm[0], g_pwm[1], g_pwm[2], g_pwm[3]);

            HAL_UART_Transmit(&huart2, (uint8_t*)tx_buf, len, 10);
        }

        /* ── Heartbeat LED ────────────────────────────────────────────── */
        HAL_GPIO_WritePin(STATUS_LED_GPIO_Port, STATUS_LED_Pin,
            (now % 1000) < 500 ? GPIO_PIN_RESET : GPIO_PIN_SET);
    }
}

/* ── UART RX interrupt callback ──────────────────────────────────────────── */
void HAL_UART_RxCpltCallback(UART_HandleTypeDef *huart)
{
    if (huart->Instance != USART2) return;

    static char  rx_line[64];
    static uint8_t rx_idx = 0;

    char c = (char)s_rx_byte;

    if (c == '\n' || c == '\r') {
        if (rx_idx > 0) {
            rx_line[rx_idx] = '\0';
            uart_rx_process(rx_line);
            rx_idx = 0;
        }
    } else if (rx_idx < sizeof(rx_line) - 1) {
        rx_line[rx_idx++] = c;
    }

    /* Re-arm for next byte */
    HAL_UART_Receive_IT(&huart2, &s_rx_byte, 1);
}

/* ── System Clock: HSE 25 MHz → PLL → 84 MHz ────────────────────────────── */
void SystemClock_Config(void)
{
    RCC_OscInitTypeDef RCC_OscInitStruct = {0};
    RCC_ClkInitTypeDef RCC_ClkInitStruct = {0};

    __HAL_RCC_PWR_CLK_ENABLE();
    __HAL_PWR_VOLTAGESCALING_CONFIG(PWR_REGULATOR_VOLTAGE_SCALE2);

    RCC_OscInitStruct.OscillatorType = RCC_OSCILLATORTYPE_HSE;
    RCC_OscInitStruct.HSEState       = RCC_HSE_ON;
    RCC_OscInitStruct.PLL.PLLState   = RCC_PLL_ON;
    RCC_OscInitStruct.PLL.PLLSource  = RCC_PLLSOURCE_HSE;
    RCC_OscInitStruct.PLL.PLLM       = 25;
    RCC_OscInitStruct.PLL.PLLN       = 168;
    RCC_OscInitStruct.PLL.PLLP       = RCC_PLLP_DIV2;
    RCC_OscInitStruct.PLL.PLLQ       = 4;
    if (HAL_RCC_OscConfig(&RCC_OscInitStruct) != HAL_OK) Error_Handler();

    RCC_ClkInitStruct.ClockType      = RCC_CLOCKTYPE_HCLK  | RCC_CLOCKTYPE_SYSCLK
                                     | RCC_CLOCKTYPE_PCLK1 | RCC_CLOCKTYPE_PCLK2;
    RCC_ClkInitStruct.SYSCLKSource   = RCC_SYSCLKSOURCE_PLLCLK;
    RCC_ClkInitStruct.AHBCLKDivider  = RCC_SYSCLK_DIV1;
    RCC_ClkInitStruct.APB1CLKDivider = RCC_HCLK_DIV2;
    RCC_ClkInitStruct.APB2CLKDivider = RCC_HCLK_DIV1;
    if (HAL_RCC_ClockConfig(&RCC_ClkInitStruct, FLASH_LATENCY_2) != HAL_OK) Error_Handler();
}

void Error_Handler(void)
{
    __disable_irq();
    while (1) {}
}
