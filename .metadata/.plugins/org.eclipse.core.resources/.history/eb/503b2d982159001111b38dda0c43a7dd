#include "main.h"
#include "tim.h"
#include "gpio.h"

void SystemClock_Config(void);

/* Helper function that perfectly mimics your proven working code */
void Set_Motor(uint8_t motor_id, int16_t speed)
{
    uint16_t pwm = (speed > 0) ? speed : -speed;

    if (motor_id == 0) /* Motor 0: PA8 / PB13 */
    {
        if (speed > 0) {
            TIM1->CCER |=  TIM_CCER_CC1E;
            TIM1->CCER &= ~TIM_CCER_CC1NE;
            TIM1->CCR1  =  pwm;
        } else if (speed < 0) {
            TIM1->CCER &= ~TIM_CCER_CC1E;
            TIM1->CCER |=  TIM_CCER_CC1NE;
            TIM1->CCR1  =  pwm;
        } else {
            TIM1->CCER &= ~(TIM_CCER_CC1E | TIM_CCER_CC1NE);
            TIM1->CCR1  =  0;
        }
    }
    else if (motor_id == 1) /* Motor 1: PA9 / PB14 */
    {
        if (speed > 0) {
            TIM1->CCER |=  TIM_CCER_CC2E;
            TIM1->CCER &= ~TIM_CCER_CC2NE;
            TIM1->CCR2  =  pwm;
        } else if (speed < 0) {
            TIM1->CCER &= ~TIM_CCER_CC2E;
            TIM1->CCER |=  TIM_CCER_CC2NE;
            TIM1->CCR2  =  pwm;
        } else {
            TIM1->CCER &= ~(TIM_CCER_CC2E | TIM_CCER_CC2NE);
            TIM1->CCR2  =  0;
        }
    }
    else if (motor_id == 2) /* Motor 2: PA10 / PB15 */
    {
        if (speed > 0) {
            TIM1->CCER |=  TIM_CCER_CC3E;
            TIM1->CCER &= ~TIM_CCER_CC3NE;
            TIM1->CCR3  =  pwm;
        } else if (speed < 0) {
            TIM1->CCER &= ~TIM_CCER_CC3E;
            TIM1->CCER |=  TIM_CCER_CC3NE;
            TIM1->CCR3  =  pwm;
        } else {
            TIM1->CCER &= ~(TIM_CCER_CC3E | TIM_CCER_CC3NE);
            TIM1->CCR3  =  0;
        }
    }
    else if (motor_id == 3) /* Motor 3: PB8 / PB9 (TIM10 & TIM11) */
    {
        if (speed > 0) {
            TIM10->CCR1 = pwm;
            TIM11->CCR1 = 0;
        } else if (speed < 0) {
            TIM10->CCR1 = 0;
            TIM11->CCR1 = pwm;
        } else {
            TIM10->CCR1 = 0;
            TIM11->CCR1 = 0;
        }
    }
}

int main(void)
{
    HAL_Init();
    SystemClock_Config();
    MX_GPIO_Init();

    /* Make sure TIM10 and TIM11 are configured in CubeMX! */
    MX_TIM1_Init();
    MX_TIM10_Init();
    MX_TIM11_Init();

    HAL_Delay(500);

    /* ── START CHANNELS (Exactly like the working code) ────────── */
    // Motor 0
    HAL_TIM_PWM_Start(&htim1, TIM_CHANNEL_1);
    HAL_TIMEx_PWMN_Start(&htim1, TIM_CHANNEL_1);
    // Motor 1
    HAL_TIM_PWM_Start(&htim1, TIM_CHANNEL_2);
    HAL_TIMEx_PWMN_Start(&htim1, TIM_CHANNEL_2);
    // Motor 2
    HAL_TIM_PWM_Start(&htim1, TIM_CHANNEL_3);
    HAL_TIMEx_PWMN_Start(&htim1, TIM_CHANNEL_3);

    __HAL_TIM_MOE_ENABLE(&htim1);

    // Motor 3
    HAL_TIM_PWM_Start(&htim10, TIM_CHANNEL_1);
    HAL_TIM_PWM_Start(&htim11, TIM_CHANNEL_1);

    /* ── MAIN LOOP ──────────────────────────────────────────────── */
    while (1)
    {
        /* FORWARD ALL */
        Set_Motor(0, 2000);
        Set_Motor(1, 2000);
        Set_Motor(2, 2000);
        Set_Motor(3, 2000);
        HAL_GPIO_WritePin(STATUS_LED_GPIO_Port, STATUS_LED_Pin, GPIO_PIN_RESET);
        HAL_Delay(3000);

        /* REVERSE ALL */
        Set_Motor(0, -2000);
        Set_Motor(1, -2000);
        Set_Motor(2, -2000);
        Set_Motor(3, -2000);
        HAL_GPIO_WritePin(STATUS_LED_GPIO_Port, STATUS_LED_Pin, GPIO_PIN_SET);
        HAL_Delay(3000);

        /* COAST ALL */
        Set_Motor(0, 0);
        Set_Motor(1, 0);
        Set_Motor(2, 0);
        Set_Motor(3, 0);
        HAL_Delay(1000);
    }
}

/* ── System Clock: HSE 25MHz → PLL → 84MHz ─────────────────────── */
void SystemClock_Config(void)
{
    RCC_OscInitTypeDef RCC_OscInitStruct = {0};
    RCC_ClkInitTypeDef RCC_ClkInitStruct = {0};

    __HAL_RCC_PWR_CLK_ENABLE();
    __HAL_PWR_VOLTAGESCALING_CONFIG(PWR_REGULATOR_VOLTAGE_SCALE2);

    RCC_OscInitStruct.OscillatorType = RCC_OSCILLATORTYPE_HSE;
    RCC_OscInitStruct.HSEState       = RCC_HSE_ON;
    RCC_OscInitStruct.PLL.PLLState   = RCC_PLL_ON;
    RCC_OscInitStruct.PLL.PLLSource  = RCC_PLLSOURCE_HSE;
    RCC_OscInitStruct.PLL.PLLM       = 25;
    RCC_OscInitStruct.PLL.PLLN       = 336;
    RCC_OscInitStruct.PLL.PLLP       = RCC_PLLP_DIV4;
    RCC_OscInitStruct.PLL.PLLQ       = 4;
    if (HAL_RCC_OscConfig(&RCC_OscInitStruct) != HAL_OK)
    {
        Error_Handler();
    }

    RCC_ClkInitStruct.ClockType      = RCC_CLOCKTYPE_HCLK | RCC_CLOCKTYPE_SYSCLK
                                     | RCC_CLOCKTYPE_PCLK1 | RCC_CLOCKTYPE_PCLK2;
    RCC_ClkInitStruct.SYSCLKSource   = RCC_SYSCLKSOURCE_PLLCLK;
    RCC_ClkInitStruct.AHBCLKDivider  = RCC_SYSCLK_DIV1;
    RCC_ClkInitStruct.APB1CLKDivider = RCC_HCLK_DIV2;
    RCC_ClkInitStruct.APB2CLKDivider = RCC_HCLK_DIV1;

    if (HAL_RCC_ClockConfig(&RCC_ClkInitStruct, FLASH_LATENCY_2) != HAL_OK)
    {
        Error_Handler();
    }
}

void Error_Handler(void)
{
    __disable_irq();
    while (1) {}
}
