/* ==============================================================================
 * RPOD CHASER - 4-MOTOR LOW LEVEL CONTROLLER
 * Hardware: STM32F401RCT6 (Black Pill) + 4x BTS7960 Drivers
 * Clock Setup: 84 MHz (HSE 25MHz -> PLL M:25, N:336, P:DIV4)
 * PWM Freq: 1 kHz (Prescaler: 19, Period: 4199) - Bypasses RC filter issue
 * ==============================================================================
 * [MOTOR WIRING - BTS7960]
 * CRITICAL DRIVER LOGIC:
 * - VCC (Logic Header) -> 3.3V on STM32
 * - R_EN & L_EN        -> 3.3V on STM32 (Always enabled)
 * - GND                -> Common GND (STM32 + 12V Supply)
 * - B+ / B-            -> 12V Power Supply
 *
 * Motor 0 (TIM1)     -> RPWM: PA8  (CH1)    | LPWM: PB13 (CH1N)
 * Motor 1 (TIM1)     -> RPWM: PA9  (CH2)    | LPWM: PB14 (CH2N)
 * Motor 2 (TIM1)     -> RPWM: PA10 (CH3)    | LPWM: PB15 (CH3N)
 * Motor 3 (TIM10/11) -> RPWM: PB8  (T10_C1) | LPWM: PB9  (T11_C1)
 * ------------------------------------------------------------------------------
 * [ENCODER WIRING] (Max Frequency, Prescaler = 0)
 * Motor 0 (TIM2) -> CHA: PA5  | CHB: PB3
 * Motor 1 (TIM3) -> CHA: PA6  | CHB: PA7  *(Note: May be PC7 based on CubeMX remap)
 * Motor 2 (TIM4) -> CHA: PB6  | CHB: PB7
 * Motor 3 (TIM5) -> CHA: PA0  | CHB: PA1
 * ------------------------------------------------------------------------------
 * [COMMUNICATIONS & MISC]
 * UART2 (Jetson) -> TX: PA2   | RX: PA3
 * Status LED     -> PC13 (Active Low)
 * ==============================================================================
 */

#include "main.h"
#include "tim.h"
#include "gpio.h"

/* ── Encoder Tracking Variables ──────────────────────────────────────────── */
volatile int32_t  enc_abs[4]   = {0, 0, 0, 0};  // Total absolute position
volatile int32_t  enc_delta[4] = {0, 0, 0, 0};  // Change since last read
uint32_t          last_raw[4]  = {0, 0, 0, 0};  // Previous raw timer value

void SystemClock_Config(void);

/* Helper function to drive all 4 motors simultaneously */
void Drive_All_Motors(int16_t speed)
{
    if (speed > 0)
    {
        /* FORWARD */
        // Motors 0, 1, 2 (TIM1 Complementary)
        TIM1->CCER |=  (TIM_CCER_CC1E | TIM_CCER_CC2E | TIM_CCER_CC3E);
        TIM1->CCER &= ~(TIM_CCER_CC1NE | TIM_CCER_CC2NE | TIM_CCER_CC3NE);
        TIM1->CCR1 = speed;
        TIM1->CCR2 = speed;
        TIM1->CCR3 = speed;
        // Motor 3 (TIM10 & TIM11 Standard)
        TIM10->CCR1 = speed;
        TIM11->CCR1 = 0;
    }
    else if (speed < 0)
    {
        /* REVERSE */
        // Motors 0, 1, 2
        TIM1->CCER &= ~(TIM_CCER_CC1E | TIM_CCER_CC2E | TIM_CCER_CC3E);
        TIM1->CCER |=  (TIM_CCER_CC1NE | TIM_CCER_CC2NE | TIM_CCER_CC3NE);
        speed = -speed;
        TIM1->CCR1 = speed;
        TIM1->CCR2 = speed;
        TIM1->CCR3 = speed;
        // Motor 3
        TIM10->CCR1 = 0;
        TIM11->CCR1 = speed;
    }
    else
    {
        /* COAST */
        // Motors 0, 1, 2
        TIM1->CCER &= ~(TIM_CCER_CC1E | TIM_CCER_CC1NE |
                        TIM_CCER_CC2E | TIM_CCER_CC2NE |
                        TIM_CCER_CC3E | TIM_CCER_CC3NE);
        TIM1->CCR1 = 0;
        TIM1->CCR2 = 0;
        TIM1->CCR3 = 0;
        // Motor 3
        TIM10->CCR1 = 0;
        TIM11->CCR1 = 0;
    }
}

void Read_All_Encoders(void)
{
    uint32_t current_raw[4];

    /* Grab the raw hardware counts */
    current_raw[0] = TIM2->CNT;
    current_raw[1] = TIM3->CNT;
    current_raw[2] = TIM4->CNT;
    current_raw[3] = TIM5->CNT;

    /* Motor 0 (TIM2, 32-bit) */
    enc_delta[0] = (int32_t)(current_raw[0] - last_raw[0]);
    enc_abs[0]  += enc_delta[0];
    last_raw[0]  = current_raw[0];

    /* Motor 1 (TIM3, 16-bit) -> MUST be cast to int16_t first! */
    enc_delta[1] = (int16_t)(current_raw[1] - last_raw[1]);
    enc_abs[1]  += enc_delta[1];
    last_raw[1]  = current_raw[1];

    /* Motor 2 (TIM4, 16-bit) -> MUST be cast to int16_t first! */
    enc_delta[2] = (int16_t)(current_raw[2] - last_raw[2]);
    enc_abs[2]  += enc_delta[2];
    last_raw[2]  = current_raw[2];

    /* Motor 3 (TIM5, 32-bit) */
    enc_delta[3] = (int32_t)(current_raw[3] - last_raw[3]);
    enc_abs[3]  += enc_delta[3];
    last_raw[3]  = current_raw[3];
}

int main(void)
{
    HAL_Init();
    SystemClock_Config();
    MX_GPIO_Init();

    /* Initialize all Timers */
    MX_TIM1_Init();
    MX_TIM10_Init();
    MX_TIM11_Init();
    MX_TIM2_Init();
    MX_TIM3_Init();
    MX_TIM4_Init();
    MX_TIM5_Init();

    HAL_Delay(500);

    /* ── START PWM CHANNELS ────────────────────────────────────────── */
    // Motor 0
    HAL_TIM_PWM_Start(&htim1, TIM_CHANNEL_1);
    HAL_TIMEx_PWMN_Start(&htim1, TIM_CHANNEL_1);
    // Motor 1
    HAL_TIM_PWM_Start(&htim1, TIM_CHANNEL_2);
    HAL_TIMEx_PWMN_Start(&htim1, TIM_CHANNEL_2);
    // Motor 2
    HAL_TIM_PWM_Start(&htim1, TIM_CHANNEL_3);
    HAL_TIMEx_PWMN_Start(&htim1, TIM_CHANNEL_3);

    // Advanced Timer Master Enable
    __HAL_TIM_MOE_ENABLE(&htim1);

    // Motor 3
    HAL_TIM_PWM_Start(&htim10, TIM_CHANNEL_1);
    HAL_TIM_PWM_Start(&htim11, TIM_CHANNEL_1);

    /* ── START ENCODERS ────────────────────────────────────────────── */
    HAL_TIM_Encoder_Start(&htim2, TIM_CHANNEL_ALL);
    HAL_TIM_Encoder_Start(&htim3, TIM_CHANNEL_ALL);
    HAL_TIM_Encoder_Start(&htim4, TIM_CHANNEL_ALL);
    HAL_TIM_Encoder_Start(&htim5, TIM_CHANNEL_ALL);

    /* ── MAIN LOOP ─────────────────────────────────────────────────── */
    while (1)
    {
        /* FORWARD ALL */
        Drive_All_Motors(2000);
        HAL_GPIO_WritePin(STATUS_LED_GPIO_Port, STATUS_LED_Pin, GPIO_PIN_RESET);
        HAL_Delay(3000);

        /* REVERSE ALL */
        Drive_All_Motors(-2000);
        HAL_GPIO_WritePin(STATUS_LED_GPIO_Port, STATUS_LED_Pin, GPIO_PIN_SET);
        HAL_Delay(3000);

        /* COAST ALL */
        Drive_All_Motors(0);
        HAL_Delay(1000);
    }
}

/* ── System Clock: HSE 25MHz → PLL → 84MHz ───────────────────────── */
void SystemClock_Config(void)
{
    RCC_OscInitTypeDef RCC_OscInitStruct = {0};
    RCC_ClkInitTypeDef RCC_ClkInitStruct = {0};

    __HAL_RCC_PWR_CLK_ENABLE();
    __HAL_PWR_VOLTAGESCALING_CONFIG(PWR_REGULATOR_VOLTAGE_SCALE2);

    RCC_OscInitStruct.OscillatorType = RCC_OSCILLATORTYPE_HSE;
    RCC_OscInitStruct.HSEState       = RCC_HSE_ON;
    RCC_OscInitStruct.PLL.PLLState   = RCC_PLL_ON;
    RCC_OscInitStruct.PLL.PLLSource  = RCC_PLLSOURCE_HSE;
    RCC_OscInitStruct.PLL.PLLM       = 25;
    RCC_OscInitStruct.PLL.PLLN       = 336;
    RCC_OscInitStruct.PLL.PLLP       = RCC_PLLP_DIV4;
    RCC_OscInitStruct.PLL.PLLQ       = 4;
    if (HAL_RCC_OscConfig(&RCC_OscInitStruct) != HAL_OK)
    {
        Error_Handler();
    }

    RCC_ClkInitStruct.ClockType      = RCC_CLOCKTYPE_HCLK | RCC_CLOCKTYPE_SYSCLK
                                     | RCC_CLOCKTYPE_PCLK1 | RCC_CLOCKTYPE_PCLK2;
    RCC_ClkInitStruct.SYSCLKSource   = RCC_SYSCLKSOURCE_PLLCLK;
    RCC_ClkInitStruct.AHBCLKDivider  = RCC_SYSCLK_DIV1;
    RCC_ClkInitStruct.APB1CLKDivider = RCC_HCLK_DIV2;
    RCC_ClkInitStruct.APB2CLKDivider = RCC_HCLK_DIV1;

    if (HAL_RCC_ClockConfig(&RCC_ClkInitStruct, FLASH_LATENCY_2) != HAL_OK)
    {
        Error_Handler();
    }
}

void Error_Handler(void)
{
    __disable_irq();
    while (1) {}
}
