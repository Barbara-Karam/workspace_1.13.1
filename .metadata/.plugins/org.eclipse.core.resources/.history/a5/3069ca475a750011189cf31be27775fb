/* ========== control_loop.c ========== */
#include "control_loop.h"
#include "encoder.h"
#include "motor_control.h"
#include "stm32f4xx_hal.h"   /* __get_PRIMASK / __disable_irq / __set_PRIMASK */

volatile ControlLoop_t g_ctrl = {0};

void ControlLoop_Init(void)
{
    for (uint8_t i = 0; i < CTRL_MOTOR_COUNT; i++) {
        g_ctrl.setpoint_rpm[i] = 0.0f;
        g_ctrl.measured_rpm[i] = 0.0f;
        g_ctrl.output_pwm[i]   = 0.0f;
        PID_Init((PID_t*)&g_ctrl.pid[i],
                 PID_KP, PID_KI, PID_KD,
                 PID_OUT_LIMIT, PID_INT_LIMIT);
    }
    g_ctrl.tick_count     = 0;
    g_ctrl.enabled        = 0;
    g_ctrl.feedback_ready = 0;
}

/* Called from TIM9 ISR at 100 Hz — no HAL or blocking calls here. */
void ControlLoop_Run(void)
{
    Encoder_Update();

    for (uint8_t i = 0; i < CTRL_MOTOR_COUNT; i++) {
        g_ctrl.measured_rpm[i] = Encoder_GetRPM(i);
    }

    if (g_ctrl.enabled) {
        for (uint8_t i = 0; i < CTRL_MOTOR_COUNT; i++) {
            g_ctrl.output_pwm[i] = PID_Update(
                (PID_t*)&g_ctrl.pid[i],
                g_ctrl.setpoint_rpm[i],
                g_ctrl.measured_rpm[i],
                CTRL_DT
            );
            Motor_Set(i, (int16_t)g_ctrl.output_pwm[i]);
        }
    } else {
        Motor_CoastAll();
    }

    g_ctrl.feedback_ready = 1;
    g_ctrl.tick_count++;
}

/* FIX #6: Atomically copy all multi-byte feedback fields in a single critical
   section.  'volatile' on g_ctrl prevents compiler reordering but does not
   prevent tearing of 4-byte floats on Cortex-M4 (LDR is not atomic relative
   to an ISR that writes the same location mid-instruction-stream).
   Returns 1 if fresh data was consumed, 0 if no new tick had fired.          */
uint8_t ControlLoop_GetSnapshot(ControlSnapshot_t *out)
{
    uint32_t primask = __get_PRIMASK();
    __disable_irq();

    uint8_t ready = g_ctrl.feedback_ready;
    if (ready) {
        for (uint8_t i = 0; i < CTRL_MOTOR_COUNT; i++) {
            out->measured_rpm[i] = g_ctrl.measured_rpm[i];
            out->output_pwm[i]   = g_ctrl.output_pwm[i];
        }
        out->tick_count       = g_ctrl.tick_count;
        g_ctrl.feedback_ready = 0;   /* consume — exactly one clear, here only */
    }

    __set_PRIMASK(primask);
    return ready;
}

void ControlLoop_SetTarget(uint8_t id, float rpm)
{
    if (id >= CTRL_MOTOR_COUNT) return;
    if (rpm >  CTRL_RPM_MAX) rpm =  CTRL_RPM_MAX;
    if (rpm < -CTRL_RPM_MAX) rpm = -CTRL_RPM_MAX;

    g_ctrl.setpoint_rpm[id] = rpm;

    /* Stop command: kill any residual integrator windup so the motor
       actually coasts instead of holding a frozen nonzero output once
       measured_rpm quantizes to 0. Safe from mainline/UART-ISR context —
       PID_Reset only touches this motor's own struct and control_loop.c
       already treats 32-bit aligned stores as safely non-torn; if you
       want to be strict about it, wrap in the same PRIMASK pattern used
       in ControlLoop_GetSnapshot(). */
    if (rpm == 0.0f) {
        PID_Reset((PID_t*)&g_ctrl.pid[id]);
    }
}

void ControlLoop_SetAllTargets(float rpm[CTRL_MOTOR_COUNT])
{
    for (uint8_t i = 0; i < CTRL_MOTOR_COUNT; i++) {
        ControlLoop_SetTarget(i, rpm[i]);
    }
}

void ControlLoop_Enable(void)
{
    for (uint8_t i = 0; i < CTRL_MOTOR_COUNT; i++) {
        PID_Reset((PID_t*)&g_ctrl.pid[i]);
    }
    g_ctrl.enabled = 1;
}

void ControlLoop_Disable(void)
{
    g_ctrl.enabled = 0;
    Motor_CoastAll();
}
