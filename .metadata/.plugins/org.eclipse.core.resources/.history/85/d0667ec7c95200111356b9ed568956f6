/* USER CODE BEGIN Header */
/**
  ******************************************************************************
  * @file    main.c
  * @brief   Blue Pill — IMU → UART test
  *          Reads MPU6050, sends ASCII lines to Jetson at 115200 baud
  *
  *  Wiring:
  *    MPU6050 VCC  → 3.3V
  *    MPU6050 GND  → GND
  *    MPU6050 SCL  → PB6
  *    MPU6050 SDA  → PB7
  *    MPU6050 AD0  → GND  (sets I2C address = 0x68)
  *
  *    UART TX → PA2  → USB-TTL RX  (or Jetson UART RX)
  *    UART RX → PA3  → USB-TTL TX  (or Jetson UART TX)
  *    GND     → GND  → shared ground with Jetson !important
  *
  *  On Jetson, run:
  *    python3 imu_receiver.py
  ******************************************************************************
  */
/* USER CODE END Header */

#include "main.h"
#include "i2c.h"
#include "usart.h"
#include "gpio.h"
#include "imu.h"

#include <stdio.h>
#include <string.h>

/* ── Globals (visible in Live Expressions) ──────────────────────────── */
IMUData_t imu_data;
uint8_t   imu_ok     = 0;
uint8_t   found_addr = 0;

/* ── Private prototypes ─────────────────────────────────────────────── */
void SystemClock_Config(void);
static void UART_Print(const char *str);

/* ── Simple blocking UART send ──────────────────────────────────────── */
static void UART_Print(const char *str)
{
    HAL_UART_Transmit(&huart2, (uint8_t *)str, (uint16_t)strlen(str), 200);
}

int main(void)
{
    /* ── Init ───────────────────────────────────────────────────────── */
    HAL_Init();
    SystemClock_Config();
    MX_GPIO_Init();
    MX_I2C1_Init();
    MX_USART2_UART_Init();

    HAL_Delay(500);  /* Let MPU6050 power rail settle */

    /* ── I2C Scan — find MPU6050 ────────────────────────────────────── */
    for (uint8_t addr = 1; addr < 128; addr++) {
        if (HAL_I2C_IsDeviceReady(&hi2c1,
                (uint16_t)(addr << 1), 2, 10) == HAL_OK) {
            found_addr = addr;  /* Watch this in Live Expressions */
        }
    }

    /* ── IMU Init ───────────────────────────────────────────────────── */
    if (found_addr == 0x68) {
        if (IMU_Init() == HAL_OK) {
            imu_ok = 1;
        }
    }

    /* ── Tell Jetson what happened ──────────────────────────────────── */
    char boot_msg[64];
    snprintf(boot_msg, sizeof(boot_msg),
        "#BOOT addr=0x%02X imu_ok=%d\r\n", found_addr, imu_ok);
    UART_Print(boot_msg);

    /* ── Main Loop ──────────────────────────────────────────────────── */
    char tx_buf[80];
    uint32_t last_read_ms   = 0;
    uint32_t last_reinit_ms = 0;
    uint8_t  fail_count     = 0;

    while (1)
    {
        uint32_t now = HAL_GetTick();

        /* Send IMU data at 10 Hz */
        if ((now - last_read_ms) >= 100)
        {
            last_read_ms = now;

            if (imu_ok)
            {
                if (IMU_Read(&imu_data) == HAL_OK)
                {
                    fail_count = 0;

                    /* Format: $IMU,ax,ay,az,gx,gy,gz,ok\r\n */
                    snprintf(tx_buf, sizeof(tx_buf),
                        "$IMU,%+.4f,%+.4f,%+.4f,%+.4f,%+.4f,%+.4f,%d\r\n",
                        imu_data.accel_x,
                        imu_data.accel_y,
                        imu_data.accel_z,
                        imu_data.gyro_x,
                        imu_data.gyro_y,
                        imu_data.gyro_z,
                        (int)imu_ok);
                    UART_Print(tx_buf);

                    /* Blink LED — heartbeat */
                    HAL_GPIO_TogglePin(GPIOC, GPIO_PIN_13);
                }
                else
                {
                    fail_count++;
                    if (fail_count >= 5) {
                        imu_ok = 0;
                        UART_Print("#ERR IMU read failed\r\n");
                    }
                }
            }
            else
            {
                /* Report failure to Jetson */
                snprintf(tx_buf, sizeof(tx_buf),
                    "#FAIL addr=0x%02X imu_ok=%d\r\n", found_addr, imu_ok);
                UART_Print(tx_buf);
            }
        }

        /* Retry IMU init every 3 seconds if failed */
        if (!imu_ok && (now - last_reinit_ms) >= 3000)
        {
            last_reinit_ms = now;
            if (IMU_Init() == HAL_OK) {
                imu_ok = 1;
                UART_Print("#REINIT OK\r\n");
            }
        }
    }
}

void SystemClock_Config(void)
{
    RCC_OscInitTypeDef RCC_OscInitStruct = {0};
    RCC_ClkInitTypeDef RCC_ClkInitStruct = {0};

    RCC_OscInitStruct.OscillatorType = RCC_OSCILLATORTYPE_HSI;
    RCC_OscInitStruct.HSIState       = RCC_HSI_ON;
    RCC_OscInitStruct.HSICalibrationValue = RCC_HSICALIBRATION_DEFAULT;
    RCC_OscInitStruct.PLL.PLLState   = RCC_PLL_ON;
    RCC_OscInitStruct.PLL.PLLSource  = RCC_PLLSOURCE_HSI_DIV2;
    RCC_OscInitStruct.PLL.PLLMUL     = RCC_PLL_MUL16;   /* 4MHz × 16 = 64MHz */
    if (HAL_RCC_OscConfig(&RCC_OscInitStruct) != HAL_OK) Error_Handler();

    RCC_ClkInitStruct.ClockType      = RCC_CLOCKTYPE_HCLK  | RCC_CLOCKTYPE_SYSCLK
                                     | RCC_CLOCKTYPE_PCLK1 | RCC_CLOCKTYPE_PCLK2;
    RCC_ClkInitStruct.SYSCLKSource   = RCC_SYSCLKSOURCE_PLLCLK;
    RCC_ClkInitStruct.AHBCLKDivider  = RCC_SYSCLK_DIV1;
    RCC_ClkInitStruct.APB1CLKDivider = RCC_HCLK_DIV2;    /* PCLK1 = 32MHz max 36 */
    RCC_ClkInitStruct.APB2CLKDivider = RCC_HCLK_DIV1;
    if (HAL_RCC_ClockConfig(&RCC_ClkInitStruct, FLASH_LATENCY_2) != HAL_OK) Error_Handler();
}

void Error_Handler(void)
{
    __disable_irq();
    while (1) {}
}
